---
import { CldImage } from 'astro-cloudinary';
interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
}
const {
  title = "Blank.428",
  subtitle = "Con dốc nhạt nhoà",
  image = "banner_h5c3t3",
} = Astro.props;
---

<div id="hero-banner">
  <div class="banner-image-wrapper">
    <CldImage
      src={image}
      width={1920}
      height={1080}
      alt={title}
      class="banner-image"
      sizes="100vw"
      fetchpriority="high"
      loading="eager"
    />
  </div>
  <div class="banner-content">
    <h1 class="banner-title">{title}</h1>
    <p class="banner-subtitle">{subtitle}</p>
  </div>
</div>

<style>
  #hero-banner {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: visible;
    margin-bottom: -200px;
    margin-top: calc(var(--header-height) * -1);
    padding-top: var(--header-height);
  }
  @media (max-width: 768px) {
    #hero-banner {
      height: 100vh;
      margin-bottom: -300px;
      margin-top: -50px;
      padding-top: 50px;
    }
  }
  .banner-image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    -webkit-mask: linear-gradient(to bottom, #000 0%, #000 60%, transparent 100%);
    mask: linear-gradient(to bottom, #000 0%, #000 60%, transparent 100%);
  }
  .banner-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.5s ease;
  }


  #hero-banner:hover .banner-image {
    transform: scale(1.05);
  }
  .banner-content {
    position: absolute;
    top: 25%;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 2rem;
    color: white;
    text-align: center;
    transform: translateY(-50%);
  }
  @media (max-width: 768px) {
    .banner-content {
      padding: 1.5rem;
      top: 20%;
    }
  }
  .banner-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 25px rgba(0, 0, 0, 0.95), 0 0 12px rgba(0, 0, 0, 0.5);
    color: var(--red-1);
    animation: glow 3s ease-in-out infinite alternate;
  }
  @media (max-width: 768px) {
    .banner-title {
      font-size: 2rem;
    }
  }
  @keyframes glow {
    from {
      filter: drop-shadow(0 0 10px rgba(255, 82, 82, 0.5));
    }
    to {
      filter: drop-shadow(0 0 20px rgba(255, 82, 82, 0.8));
    }
  }
  .banner-subtitle {
    font-size: 1.5rem;
    font-weight: 500;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.9), 0 0 8px rgba(0, 0, 0, 0.5);
    margin: 0;
  }
  @media (max-width: 768px) {
    .banner-subtitle {
      font-size: 1.1rem;
    }
  }
</style>
