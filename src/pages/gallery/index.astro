---
import Layout from "~/layouts/Layout.astro";
import AnimatedSection from "~/components/AnimatedSection.astro";
import GalleryGrid from "~/components/GalleryGrid.tsx";
---

<Layout title="Thư viện ảnh - Blank.428">
  <div class="gallery-page">
    <AnimatedSection animation="fade-up" duration={0.6}>
      <header class="gallery-header">
        <h1 class="gallery-title">Thư viện ảnh</h1>
        <p class="gallery-subtitle">
          Những khoảnh khắc đẹp trên con dốc nhạt nhoà
        </p>
      </header>
    </AnimatedSection>

    <AnimatedSection animation="fade-in" delay={0.3}>
      <GalleryGrid client:load />
    </AnimatedSection>
  </div>
</Layout>

<style is:global>
  .gallery-page {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 4rem 0.75rem 2rem;
  }

  .gallery-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 0 1rem;
  }

  .gallery-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-default);
    margin-bottom: 0.75rem;
  }

  .gallery-subtitle {
    font-size: 1.1rem;
    color: var(--grey-9);
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .gallery-page {
      padding: 2rem 1rem 1rem;
    }
    .gallery-title {
      font-size: 2rem;
    }
  }
</style>
